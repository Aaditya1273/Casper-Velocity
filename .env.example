# ArbShield Environment Configuration Template
# Copy this file to .env and fill in your values

# ============================================
# FRONTEND CONFIGURATION (REQUIRED)
# ============================================

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# WalletConnect Project ID (REQUIRED)
# Get free at: https://cloud.walletconnect.com
# 1. Create account (takes 2 minutes)
# 2. Create new project
# 3. Copy Project ID
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id_here

# Alchemy API Key (RECOMMENDED for better RPC reliability)
# Get free at: https://www.alchemy.com
NEXT_PUBLIC_ALCHEMY_API_KEY=your_alchemy_api_key_here

# Chain ID (Arbitrum Sepolia)
NEXT_PUBLIC_CHAIN_ID=421614

# ============================================
# DEPLOYED CONTRACTS (Arbitrum Sepolia)
# ============================================
# These are already deployed and working!
# You don't need to change these unless you deploy your own contracts

# ZK Verifier Wrapper (Solidity) - Main verification contract
NEXT_PUBLIC_ZK_VERIFIER=0xF2eAdA47EF443Dd5020731c01b1fEa5C2E8521Fd
NEXT_PUBLIC_STYLUS_VERIFIER=0xF2eAdA47EF443Dd5020731c01b1fEa5C2E8521Fd

# Groth16 Verifier Contract (if using full verification)
NEXT_PUBLIC_GROTH16_VERIFIER=0x46dcF690A82BbbA1D1f6fDb67EC45a2Fa7A17404

# Stylus Rust Verifier (WASM)
NEXT_PUBLIC_STYLUS_RUST_VERIFIER=0x7bca267bffc69fff991917f72d0c6b4ce9117343

# Compliance Registry
NEXT_PUBLIC_COMPLIANCE_REGISTRY=0x464D37393C8D3991b493DBb57F5f3b8c31c7Fa60

# Passkey Registry (RIP-7212)
NEXT_PUBLIC_PASSKEY_REGISTRY=0xcc00fc01c0c4749889dc6886a2ea384bba962638

# Mock BUIDL Token (Demo RWA)
NEXT_PUBLIC_MOCK_BUIDL=0xa835b811a33751e10e8fce4d8091ae55292ce518

# ============================================
# CONTRACT DEPLOYMENT (Optional - Only for deploying new contracts)
# ============================================

# Private Key (DO NOT COMMIT TO GIT!)
# Only needed if you want to deploy your own contracts
# PRIVATE_KEY=your_private_key_without_0x_prefix

# Arbitrum Sepolia RPC (for deployment)
# ARBITRUM_SEPOLIA_RPC=https://arb-sepolia.g.alchemy.com/v2/your_alchemy_key

# Arbiscan API Key (for contract verification)
# Get from: https://arbiscan.io/myapikey
# ARBISCAN_API_KEY=your_arbiscan_api_key
# ETHERSCAN_API_KEY=your_arbiscan_api_key

# ============================================
# OPTIONAL: Analytics
# ============================================

# Google Analytics Measurement ID
# NEXT_PUBLIC_GA_MEASUREMENT_ID=your_google_analytics_id

# ============================================
# EXPLORER LINKS (For Reference)
# ============================================
# ZK Verifier: https://sepolia.arbiscan.io/address/0xF2eAdA47EF443Dd5020731c01b1fEa5C2E8521Fd
# Stylus Rust: https://sepolia.arbiscan.io/address/0x7bca267bffc69fff991917f72d0c6b4ce9117343
# Compliance Registry: https://sepolia.arbiscan.io/address/0x464D37393C8D3991b493DBb57F5f3b8c31c7Fa60
# Passkey Registry: https://sepolia.arbiscan.io/address/0xcc00fc01c0c4749889dc6886a2ea384bba962638
# Mock BUIDL: https://sepolia.arbiscan.io/address/0xa835b811a33751e10e8fce4d8091ae55292ce518

# ============================================
# QUICK START
# ============================================
# 1. Copy this file: cp .env.example .env
# 2. Get WalletConnect Project ID from https://cloud.walletconnect.com
# 3. (Optional) Get Alchemy API Key from https://www.alchemy.com
# 4. Run: npm run dev
# 5. Open: http://localhost:3000

