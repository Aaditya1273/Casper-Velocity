# Stylus Rust Verifier Deployment Configuration Template
# Copy this file to .env and fill in your values

# ============================================
# DEPLOYMENT CONFIGURATION
# ============================================

# Your wallet private key (without 0x prefix)
# NEVER commit this file with real keys!
PRIVATE_KEY=your_private_key_without_0x_prefix

# RPC endpoint
# Testnet (Arbitrum Sepolia):
RPC_URL=https://sepolia-rollup.arbitrum.io/rpc

# Or use Alchemy for better reliability:
# RPC_URL=https://arb-sepolia.g.alchemy.com/v2/your_alchemy_api_key

# For mainnet deployment, use:
# RPC_URL=https://arb1.arbitrum.io/rpc

# ============================================
# DEPLOYED CONTRACT (For Reference)
# ============================================

# Current deployed Stylus contract on Arbitrum Sepolia
STYLUS_CONTRACT_ADDRESS=0x7bca267bffc69fff991917f72d0c6b4ce9117343

# Explorer Link:
# https://sepolia.arbiscan.io/address/0x7bca267bffc69fff991917f72d0c6b4ce9117343

# ============================================
# DEPLOYMENT INSTRUCTIONS
# ============================================
# 1. Copy this file: cp .env.example .env
# 2. Add your private key (without 0x prefix)
# 3. (Optional) Add Alchemy RPC URL for better reliability
# 4. Run: ./deploy.sh testnet
# 5. Save the deployed contract address
# 6. Update frontend: ./update-frontend.sh <contract_address>

